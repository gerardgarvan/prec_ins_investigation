# Data files (HIPAA protected, not in version control)
data/
*.sas7bdat
*.sas7bcat

# R environment
.Rhistory
.RData
.Rproj.user/

# renv library (large, reproducible from lockfile)
renv/library/
renv/staging/
renv/sandbox/
renv/cellar/

# Output files (regenerated by pipeline)
output/

# OS files
.DS_Store
Thumbs.db

# Keep these IN version control:
# renv.lock (package versions)
# renv/activate.R (renv bootstrap)
# renv/settings.json (renv config)
# R/*.R (all pipeline scripts)
# .Rprofile (renv activation)
